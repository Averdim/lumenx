# 阿里云 DashScope API Key (用于通义千问等模型)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# MinIO / S3 兼容存储 (可选，用于图片/视频对象键与预签名 URL)
# MINIO_ENDPOINT 可为 host:port 或完整 URL（本机/内网，用于上传与读对象）
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lumenx
MINIO_USE_SSL=false
MINIO_BASE_PATH=lumenx
# 内网穿透后的公网地址，仅用于生成预签名 GET URL（阿里云等需能访问该地址拉图）
# 不设则预签名里的主机与 MINIO_ENDPOINT 相同（localhost 时云端无法拉取）
# MINIO_PUBLIC_ENDPOINT=https://your-subdomain.ngrok-free.app
# MINIO_PUBLIC_USE_SSL=true
# MINIO_REGION=us-east-1

# Kling AI 配置 (可选，用于 Kling 视频生成)
KLING_ACCESS_KEY=your_kling_access_key_here
KLING_SECRET_KEY=your_kling_secret_key_here

# Vidu AI 配置 (可选，用于 Vidu 视频生成)
VIDU_API_KEY=your_vidu_api_key_here

# 火山引擎方舟 API Key（可选；视频任务 model 为 doubao-* 或 seedance* 前缀时走 Ark / Seedance I2V）
ARK_API_KEY=your_doubao_ark_api_key_here
# 可选：与方舟控制台推理接入点一致时覆盖默认 Seedance 2.0 模型 id
# ARK_SEEDANCE_MODEL=doubao-seedance-2-0-260128
# Seedance 1.5 Pro (first-frame I2V): doubao-seedance-1-5-pro-251215

# 文生图 / OpenAI 兼容生图网关（与 LLM 的 OPENAI_* 分开，避免与 DashScope 或 LLM 中转互相覆盖）
# 以下模型共用本组 Base URL + Key（仅接口路径不同）：Gemini Flash Image → chat/completions；
# Seedream3.0 / z-image-turbo → /v1/images/generations；有参考图时在同一 JSON 里附带参考图（默认字段 image=base64）
# 可选：IMAGE_GENERATIONS_REF_IMAGE_FIELD=input_image（JSON 字段名）
# 可选：IMAGE_GENERATIONS_REF_IMAGE_MODE=base64|data_uri|url（url 时要求参考图解析为公网 https URL）
# 可选：IMAGE_GENERATIONS_REF_IMAGE_URL_FIELD=image_url（MODE=url 时写入的字段名，默认同 REF_IMAGE_FIELD）
IMAGE_OPENAI_BASE_URL=https://api.aibh.site
IMAGE_OPENAI_API_KEY=sk-FwH0O6d6FtpDs27N2oox3z9WtCTHsKcXqX3XCje3ccOyS9qC
# 兼容别名（二选一即可）
# KONGYANG_BASE_URL=https://api.example.com/v1

# 可选：真网关冒烟（消耗额度）tests/test_live_recent_models.py — 需配好上方 LLM / IMAGE 凭证后：
# RUN_LIVE_NEW_MODELS=1
# pytest tests/test_live_recent_models.py -v

# LLM 多模型适配 (可选)
# 文字模型路由（见 src/utils/llm_provider_registry.py）：
# qwen* → DASHSCOPE_API_KEY + DashScope compatible-mode
# gpt-5.2-kongyang → 空氧；gpt-5-2-geeknow → GeekNow；上游会去掉 -kongyang / -geeknow 后缀
# gpt-* / o1* / o3* / deepseek* / custom-* / gemini* → 空氧通道 openai_kongyang（凭证见下）
# 未匹配任何前缀时回退 LLM_PROVIDER：openai → 同样走空氧通道；dashscope → 千问侧
#
# 空氧（推荐变量名；未配置时回退到旧名 OPENAI_*）:
# OPENAI_KONGYANG_API_KEY=...
# OPENAI_KONGYANG_BASE_URL=https://你的空氧/v1
# 若暂未迁移，仅保留下面两行也可（等同空氧）:
# OPENAI_API_KEY=...
# OPENAI_BASE_URL=https://你的空氧/v1
#
# LLM_PROVIDER=openai   # 无前缀匹配时走空氧（gemini* 已前缀匹配空氧，此项主要影响其它未知 id）
# OPENAI_MODEL=gpt-5.2
# LLM_DEFAULT_MODEL=qwen3.5-plus
#
# GeekNow（与空氧并存时在项目「LLM channel」选 openai_geeknow）:
# OPENAI_GEEKNOW_API_KEY=...
# OPENAI_GEEKNOW_BASE_URL=https://你的geeknow/v1
#
# DeepSeek / Ollama 等仍设 LLM_PROVIDER=openai，Base/Key 用空氧变量或 legacy OPENAI_* 即可。
#
# 每个项目/剧集可在前端「生成设置」中设置 llm_model / llm_backend。

# API 服务配置
API_HOST=0.0.0.0
API_PORT=8000

# ===============================
# API 端点配置 (可选，海外部署时切换到国际端点)
# 命名约定: {PROVIDER}_BASE_URL
# ===============================
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com
# KLING_BASE_URL=https://api.klingai.com/v1
# VIDU_BASE_URL=https://api.vidu.cn/ent/v2
# OPENAI_KONGYANG_BASE_URL=https://你的空氧/v1
# OPENAI_GEEKNOW_BASE_URL=https://你的geeknow/v1
